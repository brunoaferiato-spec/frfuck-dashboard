{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,

    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",

    "moduleResolution": "bundler",

    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,

    "types": ["node", "vite/client"],

    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}